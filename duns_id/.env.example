# =============================================================================
# FCA Broker Lookup — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env      (Mac/Linux)
#   copy .env.example .env    (Windows)
#
# NEVER commit .env to source control.
# =============================================================================

FCA_BASE_URL=https://zuul-gateway-pt-a-25961.np4.apaas4.barclays.intranet/fcabrokerquery-api/2/internal/call
FCA_BEARER_TOKEN=your_bearer_token_here
FCA_CHANNEL_ID=G01365404
FCA_AUTH_EMAIL=corporatertbcdtpservice12@barclays.com
FCA_AUTH_KEY=your_auth_key_here
FCA_CORRELATION_ID=your_correlation_id_here
FCA_REQUEST_DELAY_SECONDS=0.5

# ── SSL certificate verification ─────────────────────────────────────────────
# Option A: point to your corporate CA bundle (recommended for Barclays internal)
#   FCA_SSL_CA_CERT=C:\Users\x01594717\Downloads\ca_all.pem
#
# Option B: disable verification entirely (same as Insomnia "Validate certs OFF")
#   FCA_SSL_CA_CERT=false
#
# Option C: leave blank → use Python's default certifi bundle
#   FCA_SSL_CA_CERT=
# ─────────────────────────────────────────────────────────────────────────────
FCA_SSL_CA_CERT=C:\Users\x01594717\Downloads\ca_all.pem
